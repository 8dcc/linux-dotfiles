#!/bin/bash

# List of authors whose commits should not be pushed.
BLOCKED_AUTHORS=(
    "8dcc.git@gmail.com"
)

while read local_ref local_sha remote_ref remote_sha; do
    # Deletions have a null local_sha — nothing to scan.
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # When pushing a new branch that doesn't exist on the remote, git uses a
    # null hash as the remote.
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        emails=$(git log "$local_sha" --format="%ae%n%ce")
    else
        emails=$(git log "$remote_sha..$local_sha" --format="%ae%n%ce")
    fi

    # Check if any commit exposes a blocked email (author or committer).
    for blocked in "${BLOCKED_AUTHORS[@]}"; do
        if echo "$emails" | grep -q "^$blocked$"; then
            echo "Push rejected: a commit exposes email $blocked. Check your git identity for this repo."
            exit 1
        fi
    done
done

exit 0
