+	MWS(selmon).lt[MWS(selmon).sellt^1] = MWS(selmon).pertag->ltidxs[MWS(selmon).pertag->curtag][MWS(selmon).sellt^1];
+
+	if (selmon->showbar != MWS(selmon).pertag->showbars[MWS(selmon).pertag->curtag])
