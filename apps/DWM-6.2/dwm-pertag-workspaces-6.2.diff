+	int i;
 
 	if (newtagset) {
 		MWS(selmon).tagset[MWS(selmon).seltags] = newtagset;
+
+		if (newtagset == ~0) {
+			MWS(selmon).pertag->prevtag = MWS(selmon).pertag->curtag;
+			MWS(selmon).pertag->curtag = 0;
